{
  "name": "hors",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "workspaces": [
        "packages/base",
        "packages/advanced",
        "packages/utils"
      ],
      "devDependencies": {}
    },
    "node_modules/@hors/base": {
      "resolved": "packages/base",
      "link": true
    },
    "node_modules/@hors/utils": {
      "resolved": "packages/utils",
      "link": true
    },
    "packages/advanced": {
      "name": "@hors/advanced",
      "version": "1.0.0",
      "extraneous": true,
      "license": "MIT",
      "dependencies": {
        "@hors/base": "^1.0.0"
      },
      "engines": {
        "node": ">=16.0.0"
      }
    },
    "packages/base": {
      "name": "@hors/base",
      "version": "1.0.0",
      "license": "MIT",
      "engines": {
        "node": ">=16.0.0"
      }
    },
    "packages/utils": {
      "name": "@hors/utils",
      "version": "1.0.0",
      "license": "MIT",
      "engines": {
        "node": ">=16.0.0"
      }
    }
  }
}
